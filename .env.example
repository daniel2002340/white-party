# Copy this file to .env and fill in real values. Never commit .env.

# --- Database (SQLite via Prisma) ---
# Relative SQLite paths are resolved from the prisma/ directory (where schema.prisma lives),
# so "../data/app.db" points at ./data/app.db in the project root.
DATABASE_URL="file:../data/app.db"

# --- Application ---
# 32+ byte random secret used to sign/encrypt session cookies. Generate with: openssl rand -base64 32
SESSION_SECRET=""
# Public base URL of the site, used for links in emails (no trailing slash). E.g. https://feest.example.nl
APP_URL="http://localhost:3000"

# --- Email (plain SMTP via nodemailer) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# From address for outgoing mail. E.g. "Het Feest <noreply@feest.example.nl>"
SMTP_FROM=""

# --- Photo storage (Cloudflare R2, S3-compatible) ---
# The bucket must be PRIVATE (all access via presigned URLs). See CLAUDE.md for
# the required CORS policy. If these are left empty in development, photos are
# stored on local disk under ./data/r2-dev instead (dev-only fallback).
# R2 S3 API endpoint. E.g. https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# --- Initial admin (used by the seed script) ---
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
